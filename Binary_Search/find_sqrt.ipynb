   "source": [
    "def find_sqrt(x):\n",
    "    low, high = 0, x\n",
    "    while low<=high:\n",
    "        mid=(low+high)//2\n",
    "        if mid**2>x:\n",
    "            high=mid-1\n",
    "        else:\n",
    "            low=mid+1\n",
    "    return high\n",
    "\n",
    "find_sqrt(10)"
   ]
  }
 ],
