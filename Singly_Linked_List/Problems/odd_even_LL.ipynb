   "source": [
    "def oddEvenList(self, head):\n",
    "    odd=head\n",
    "    even=head.next\n",
    "    even_head=head.next\n",
    "    while even and even.next:\n",
    "        odd.next=even.next\n",
    "        odd=odd.next\n",
    "\n",
    "        even.next=odd.next\n",
    "        even=even.next\n",
    "    odd.next=even_head\n",
    "    return head"
   ]
  }
 ],
