   "source": [
    "def getIntersectionNode(self, headA, headB):\n",
    "    t1=headA\n",
    "    t2=headB\n",
    "    while t1!=t2:\n",
    "        t1=headB if not t1 else t1.next\n",
    "        t2=headA if not t2 else t2.next\n",
    "    return t1"
   ]
  }
